local function Decode(data: string): string
    local KEY = 37
	data = data:sub(3)
	local result = {}
	for i = 1, #data, 2 do
		local hex = data:sub(i, i + 1)
		local byte = tonumber(hex, 16) :: number
		byte -= KEY
		table.insert(result, string.char(byte))
	end
	return table.concat(result)
end

loadstring(Decode(""))()